# Copy to .env and fill in. Never commit .env.

# LLM (Groq) — required for summarizer, slides, quiz, chat agents
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# Optional: override data locations (defaults: ./data/...)
# APP_DATA_DIR=
# KNOWLEDGE_BASE_DIR=
# VECTOR_STORE_PATH=
# UPLOADS_DIR=
# PARSED_DIR=
