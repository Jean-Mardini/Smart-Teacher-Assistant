# Copy to .env and fill in. Never commit .env.

# PDF math: set PDF_FORMULA_OCR=1 to run LaTeX-OCR (pix2tex) on embedded equation-sized images when parsing PDFs
# (summarize / library indexing). Install once: pip install pix2tex — first run downloads weights; CPU is slow.
# Cap attempts per document with PDF_FORMULA_OCR_MAX (default 25). Vector-only math (no bitmap) is not extracted here.
# PDF_FORMULA_OCR=0
# PDF_FORMULA_OCR_MAX=25

# PPTX export: SLIDE_EXPORT_HTML=1 (default) renders each slide as HTML/CSS and screenshots with Playwright (install: python -m playwright install chromium). Set 0 to use legacy python-pptx positioning only.
# SLIDE_EXPORT_HTML=1

# LLM (Groq) — one key for all features: agents, chat, and evaluation (Kristy grader)
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# Flexible Grader — batch: parallel workers (default 1 to avoid Groq TPM 429 overlap on on_demand).
# GRADE_BATCH_MAX_PARALLEL=1
# Seconds between each file in HTTP batch grading (default 1). Raise only if you still see 429.
# GRADE_BATCH_SUBMISSION_GAP_SEC=1
# Batch: rubric rows per Groq call when rubric is large (optional; if unset, code picks 4–8). Small rubrics use one call.
# GRADE_BATCH_ITEMS_PER_CALL=
# Up to this many rubric rows = one Groq call per file in batch (default 10).
# GRADE_BATCH_SINGLE_CALL_MAX_ITEMS=10
# Pause between chunk calls when rubric is split (default 0.35s).
# GRADE_BATCH_CHUNK_GAP_SEC=0.35
# Split rubric across smaller Groq calls. Default 0 = one Groq call for the whole rubric (fastest). Set e.g. 3 if you hit 429 on huge rubrics.
# GRADE_ITEMS_PER_LLM_CALL=0
# Seconds between chunk calls when GRADE_ITEMS_PER_LLM_CALL>0 (default 0).
# GRADE_LLM_CHUNK_GAP_SEC=0
# Optional reproducibility for grading JSON (only if your Groq model accepts seed).
# GROQ_GRADE_SEED=42
# Max chars of student + teacher key per request (default 12000). Lower if you still hit 429.
# GROQ_GRADE_PROMPT_MAX_CHARS=12000
# Cap JSON completion tokens for grading (default 2048). Set 0 to omit.
# GROQ_GRADE_MAX_COMPLETION_TOKENS=2048

# Slide deck text (Groq JSON): SLIDE_GENERATION_FAST=1 (default) uses shorter speaker-note targets, compact
# templates, a 9000-char source excerpt (when GROQ_SLIDE_SOURCE_MAX_CHARS is unset), and fewer HF image retries.
# Set SLIDE_GENERATION_FAST=0 for the previous richer (usually slower) slide copy.
# SLIDE_GENERATION_FAST=1
# GROQ_SLIDE_SOURCE_MAX_CHARS=12000

# Slide images (Groq does not generate images).
# Defaults need NO keys: local PNG placeholders per slide. Add keys only when you want real AI/stock imagery.
#
# SLIDE_IMAGE_HF_ONLY=0              # default — omit or 0 = classic mode (HF/xAI/OpenAI when keys exist; else placeholders)
# SLIDE_IMAGE_HF_ONLY=1             # optional — try HF first each slide; then SLIDE_IMAGE_FALLBACK_AFTER_HF chain
# SLIDE_IMAGE_FALLBACK_AFTER_HF=1    # when HF_ONLY=1: after HF fails → Pexels/Unsplash → xAI → OpenAI (if keys set)
# SLIDE_IMAGE_HF_RETRIES_PER_SLIDE=5
# SLIDE_IMAGE_LAST_RESORT_PLACEHOLDER=1  # if all APIs fail, draw local PNG (default on)
#
# Legacy / optional (only when SLIDE_IMAGE_HF_ONLY=0):
# SLIDE_IMAGE_TRY_ORDER=huggingface,xai,openai
# SLIDE_IMAGE_TRY_ALL_PROVIDERS=1
# SLIDE_IMAGE_FULL_CHAIN_RETRIES=2
#
# Royalty-free stock (Pexels / Unsplash APIs — legal “web search” for photos; not random hotlinking).
# When AI (HF/Pollinations) fails, try stock before the gradient placeholder (default on if a key is set):
# SLIDE_IMAGE_STOCK_ON_AI_FAIL=1
# SLIDE_IMAGE_STOCK_ENABLED=1   # default on — set 0 to disable all stock fetches
#
# Stock photos from the web (optional mix mode — AI + stock rotation). Enable only if SLIDE_IMAGE_HF_ONLY=0:
# SLIDE_IMAGE_MIX_ENABLE=1
# SLIDE_IMAGE_MIX_MODE=stock_first
# PEXELS_API_KEY=
# UNSPLASH_ACCESS_KEY=
#
# If SLIDE_IMAGE_PROVIDER is unset: HF_TOKEN -> XAI_API_KEY -> OPENAI_API_KEY for *selection* of primary;
# if none of those keys are set, local PNG placeholders are drawn (SLIDE_IMAGE_NOAPI_PLACEHOLDERS=1 default).
# SLIDE_IMAGE_PROVIDER=placeholder   # force local drawings only: demo | hf | xai | openai | huggingface
# SLIDE_IMAGE_NOAPI_PLACEHOLDERS=1   # set 0 to disable auto placeholders when you have no image API keys
# SLIDE_IMAGE_FALLBACK_PLACEHOLDERS=0   # set 1 to use local drawings if HF/xAI/OpenAI image calls fail
# SLIDE_IMAGE_PROVIDER=huggingface   # or: hf | xai | openai
# HF_TOKEN=   # required on the API machine for real topic images (e.g. photosynthesis art); else only local previews
# HUGGING_FACE_HUB_TOKEN=   # same as HF_TOKEN on many setups
# HF_IMAGE_MODEL=stabilityai/sdxl-turbo
# (optional) black-forest-labs/FLUX.1-schnell — also try REST fallbacks: sdxl-turbo, stable-diffusion-2
# HF_INFERENCE_PROVIDER=auto   # e.g. hf-inference — see Hugging Face Inference docs
# HF_IMAGE_WIDTH=1024
# HF_IMAGE_HEIGHT=576
# HF_INFERENCE_TIMEOUT=75
# Speed (defaults tuned for faster decks):
# SLIDE_IMAGE_PARALLEL_LIVE=1      # optional — parallel HF/image calls for live JSON deck (default off; Windows may blank slides)
# SLIDE_IMAGE_PARALLEL=8           # threads for live slide images + teacher-deck attachment + PPTX prep (1–8)
# HF_INFERENCE_TIMEOUT=75        # seconds per HF image call (raise if FLUX cold-starts timeout)
# SLIDE_IMAGE_FULL_CHAIN_RETRIES=1  # HF→xAI→OpenAI rounds when TRY_ALL_PROVIDERS=1
# SLIDE_IMAGE_HF_RETRIES_PER_SLIDE=1  # only when SLIDE_IMAGE_HF_ONLY=1
# POLLINATIONS_TIMEOUT=50        # Pollinations HTTP timeout (seconds; default 50)
#
# HF_IMAGE_PROMPT_MAX_CHARS=1600   # long prompts can break some endpoints; image code truncates for HF
# HF_IMAGE_EXTENDED_PARAMS=0      # default off — FLUX/Router reject negative_prompt/guidance (was causing blank images)
# HF_IMAGE_GUIDANCE_SCALE=6.5     # only used when HF_IMAGE_EXTENDED_PARAMS=1
# HF_IMAGE_FALLBACK_MODEL=        # optional backup model id if primary model errors (e.g. stabilityai/sdxl-turbo)
#
# Free fallback when HF hits 402 / no quota (no API key — uses image.pollinations.ai):
# SLIDE_IMAGE_POLLINATIONS_FALLBACK=1   # default on; set 0 to disable
# SLIDE_IMAGE_POLLINATIONS_FIRST=1      # optional — try Pollinations *before* HF (no billing; slower per slide)
# POLLINATIONS_IMAGE_WIDTH=1024
# POLLINATIONS_IMAGE_HEIGHT=576
# XAI_API_KEY=
# XAI_IMAGE_MODEL=grok-imagine-image
# XAI_IMAGE_ASPECT_RATIO=16:9
# XAI_IMAGE_RESOLUTION=1k
# OPENAI_API_KEY=
# OPENAI_IMAGE_MODEL=gpt-image-1

# Optional: summarizer chunking (defaults tuned for fewer round-trips + more parallelism)
# SUMMARY_CHUNK_SIZE=22000
# SUMMARY_MAX_PARALLEL=6
# If Groq returns many 429s, lower to SUMMARY_MAX_PARALLEL=2–3 or SUMMARY_CHUNK_SIZE=14000
# Groq on_demand TPM: chat completions auto-retry on 429 (tune if needed; default 20)
# GROQ_RATE_LIMIT_RETRIES=20
# GROQ_RATE_LIMIT_MAX_WAIT_SEC=120
# GROQ_RATE_LIMIT_FALLBACK_SEC=2.5
# Summarize RAG (optional retrieval input instead of full text)
# SUMMARY_RAG_CHAR_THRESHOLD=55000
# SUMMARY_RAG_MULTI_DOC_CHAR_THRESHOLD=50000
# SUMMARY_RAG_TOP_K=28
# SUMMARY_RAG_CHUNK_CHARS=1400   # max chars per retrieved chunk (speed)
# SUMMARY_RAG_INPUT_CAP=38000    # max total RAG context sent to the model (often → single LLM call)
# SUMMARY_RAG_FORCE_PAGES=70     # auto RAG when a single doc has at least this many pages
# SUMMARY_FALLBACK_MIN_CHARS=90000   # if RAG is nearly empty but extraction is huge, use excerpt fast path
# SUMMARY_FALLBACK_EXCERPT_CHARS=52000
# Optional: large slide decks (defaults: 400 pages / 600000 chars of extracted text)
# MAX_SUMMARY_PAGES=400
# MAX_SUMMARY_CHARS=600000

# Optional: override data locations (defaults: ./data/...)
# APP_DATA_DIR=
# KNOWLEDGE_BASE_DIR=
# VECTOR_STORE_PATH=
# UPLOADS_DIR=
# PARSED_DIR=
